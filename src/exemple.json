
{
  "name": "Modern Blue Theme",
  "version": "1.0",
  "colors": {
    "primary": "#2563eb",
    "primaryHover": "#1d4ed8",
    "secondary": "#9333ea",
    "background": "#f9fafb",
    "surface": "#ffffff",
    "text": "#111827",
    "textSecondary": "#6b7280",
    "border": "#e5e7eb",
    "success": "#16a34a",
    "error": "#dc2626",
    "warning": "#f59e0b"
  },
  "typography": {
    "fontFamily": "Inter, sans-serif",
    "h1": {
      "fontSize": "2.5rem",
      "fontWeight": "700",
      "lineHeight": "1.2"
    },
    "h2": {
      "fontSize": "2rem",
      "fontWeight": "600",
      "lineHeight": "1.3"
    },
    "h3": {
      "fontSize": "1.5rem",
      "fontWeight": "600",
      "lineHeight": "1.4"
    },
    "body": {
      "fontSize": "1rem",
      "fontWeight": "400",
      "lineHeight": "1.6"
    },
    "small": {
      "fontSize": "0.875rem",
      "fontWeight": "400"
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "borderRadius": {
    "sm": "6px",
    "md": "12px",
    "lg": "20px"
  },
  "buttons": {
    "primary": {
      "background": "#2563eb",
      "color": "#ffffff",
      "padding": "12px 20px",
      "borderRadius": "12px"
    },
    "secondary": {
      "background": "#e5e7eb",
      "color": "#111827",
      "padding": "12px 20px",
      "borderRadius": "12px"
    }
  },
  "cards": {
    "background": "#ffffff",
    "padding": "20px",
    "borderRadius": "16px",
    "shadow": "0 10px 25px rgba(0,0,0,0.05)"
  },
  "navbar": {
    "background": "#ffffff",
    "textColor": "#111827",
    "height": "70px",
    "borderBottom": "1px solid #e5e7eb"
  },
  "footer": {
    "background": "#111827",
    "textColor": "#ffffff",
    "padding": "40px"
  }
}
